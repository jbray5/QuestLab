[flake8]
max-line-length = 100
exclude =
    .venv,
    .git,
    __pycache__,
    alembic/versions,
    data,
    static,
    frontend
extend-ignore = E203, W503
per-file-ignores =
    integrations/dnd_rules/stat_blocks.py: E501
    integrations/dnd_rules/srd_spells_2024.py: E501
    integrations/dnd_rules/class_features_2024.py: E501
