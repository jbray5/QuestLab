# ── Database ──────────────────────────────────────────────────────────────────
DB_BACKEND=postgres                      # postgres | duckdb

# Postgres (required when DB_BACKEND=postgres)
PGHOST=localhost
PGPORT=5432
PGDATABASE=questlab
PGUSER=questlab
PGPASSWORD=changeme
PGSSLMODE=require

# DuckDB (used for local dev / tests when DB_BACKEND=duckdb)
DUCKDB_PATH=./data/app.duckdb

# ── Auth ──────────────────────────────────────────────────────────────────────
# Header injected by Azure Front Door + Entra ID (prod only)
AUTH_EMAIL_HEADER=X-MS-CLIENT-PRINCIPAL-NAME

# Local dev fallback — NEVER set in prod
CURRENT_USER_EMAIL=dev@local.test

# Seeded into admins table on first run when table is empty
BOOTSTRAP_ADMIN_EMAILS=admin@example.com

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=development                          # development | production
