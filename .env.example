# ── Database ──────────────────────────────────────────────────────────────────
DB_BACKEND=postgres                      # postgres | duckdb

# Postgres (required when DB_BACKEND=postgres)
PGHOST=localhost
PGPORT=5432
PGDATABASE=questlab
PGUSER=questlab
PGPASSWORD=changeme
PGSSLMODE=require

# DuckDB (used for local dev / tests when DB_BACKEND=duckdb)
DUCKDB_PATH=./data/app.duckdb

# ── Auth ──────────────────────────────────────────────────────────────────────
# Header injected by Azure Front Door + Entra ID (prod only)
AUTH_EMAIL_HEADER=X-MS-CLIENT-PRINCIPAL-NAME

# Local dev fallback — NEVER set in prod
CURRENT_USER_EMAIL=dev@local.test

# Seeded into admins table on first run when table is empty
BOOTSTRAP_ADMIN_EMAILS=admin@example.com

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OpenAI — used by portrait generation (Plan 00034). Leave blank to
# disable portrait generation; the rest of the app works without it.
OPENAI_API_KEY=sk-your-key-here

# Vercel Blob — used to store generated portraits durably (Render's free
# tier filesystem is ephemeral). Create a store in Vercel dashboard →
# Storage → Blob → copy the read-write token.
BLOB_READ_WRITE_TOKEN=

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=development                          # development | production

# ── CORS (production deployments) ─────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API in
# production. Localhost dev origins are always allowed by default.
# Example for Vercel + Render split deploy:
#   CORS_ORIGINS=https://questlab.vercel.app
CORS_ORIGINS=

# ── Frontend (Vite) — set in Vercel, NOT in this file ─────────────────────────
# When the frontend is hosted separately from the API (Vercel + Render),
# set VITE_API_BASE_URL in Vercel's project env vars to the absolute backend
# URL including the /api prefix. Frontend reads it via import.meta.env.
# Empty / unset keeps the local Vite dev proxy ("/api" → localhost:8000).
# Example:
#   VITE_API_BASE_URL=https://questlab-api.onrender.com/api
# Optional: pre-fill the DM identity input on first load:
#   VITE_DM_EMAIL=you@example.com
