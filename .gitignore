# ── Secrets & environment ──────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
# "lib/" rule scoped to the repo root so the frontend's src/lib/ JS
# utility folder (a JS convention) isn't swept up by what was meant for
# Python packaging build artifacts.
/lib/
lib64/
wheels/

# ── Virtual environment ────────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Campaign backups (prod DB snapshots + player PII — never commit) ──────────
# The existing campaigns/backups/ snapshot is still tracked; untrack it with
#   git rm -r --cached campaigns/backups/
# (Plan 41 — it contains dm_email + player_name from a live export.)
campaigns/backups/

# ── Database files ─────────────────────────────────────────────────────────────
data/
*.duckdb
*.duckdb.wal
*.db
*.sqlite
*.sqlite3

# ── Alembic (keep versions, ignore generated temp files) ──────────────────────
# alembic/versions/ is intentionally tracked

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ── Linting & tools ───────────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Claude Code (local session data) ─────────────────────────────────────────
.claude/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# Serena MCP server working directory
.serena/

# Local cache for one-shot SRD parsing scripts
scripts/.srd_*.md
