# Normalize line endings to LF in the repo; checkout as-is on all platforms
* text=auto eol=lf
*.py text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.txt text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf

# Binaries — no line ending conversion
*.png binary
*.jpg binary
*.ico binary
*.duckdb binary
